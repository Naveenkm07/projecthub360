# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Admin credentials (Firestore — set via Firebase console)
NEXT_PUBLIC_ADMIN_EMAIL=admin@protobuildlabs.in

# Razorpay (SERVER-SIDE ONLY — never expose to client)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Public Razorpay key (safe to expose — only for checkout UI)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id
